rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function hasRole(role) {
      return isSignedIn() && getUserData().role == role;
    }

    // User profiles
    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || hasRole('admin'));
      allow write: if hasRole('admin');
    }

    // Leads / Project Briefs
    match /leads/{leadId} {
      allow read: if hasRole('admin') || (isSignedIn() && request.auth.uid == resource.data.clientId);
      allow create: if true; // Public can submit leads
      allow update, delete: if hasRole('admin');
    }

    // Projects
    match /projects/{projectId} {
      allow read: if hasRole('admin') || (isSignedIn() && request.auth.uid == resource.data.clientId);
      allow write: if hasRole('admin');
    }
    
    // Blog Posts
    match /blog/{postId} {
      allow read: if true; // Public can read
      allow write: if hasRole('admin');
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
